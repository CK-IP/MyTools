{
  "_comment": "Reference copy of ~/.claude/settings.json — DO NOT symlink this file. cc-dotfiles merges into the real settings.json, so it must remain a regular file. Use this as a guide for what to configure.",

  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",

    "_comment_sail": "/sail model allocation (codex builds / claude reviews per the #83 cross-family invariant). SAIL_REVIEW_CMD2 and SAIL_TIDINESS_VERIFY_CMD are intentionally absent — see commands/sail.md.",
    "SAIL_BUILD_CMD": "codex exec -m gpt-5.4-mini",
    "SAIL_REVIEW_CMD": "claude -p --model sonnet",
    "SAIL_REVIEW_CMD_ESCALATED": "claude -p --model opus",
    "SAIL_REVIEW_ESCALATE_ROUND": "3",
    "SAIL_REDTEAM_CMD": "claude -p --model opus",
    "SAIL_PLAN_CMD": "claude -p --model opus",
    "SAIL_PLAN_CMD2": "codex exec -m gpt-5.5 -c model_reasoning_effort=high",
    "SAIL_PLAN_GROUNDED_CMD": "codex exec -m gpt-5.5 -c model_reasoning_effort=high",
    "SAIL_TIDINESS_CMD": "claude -p --model haiku",
    "SAIL_MATERIALITY_CMD": "codex exec -m gpt-5.5 -c model_reasoning_effort=high"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Glob",
      "Grep",
      "Read",
      "WebFetch(domain:unpkg.com)",
      "Write"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-opus-4-6",
  "hooks": {
    "_comment_hooks": "cc-dotfiles installs its own hooks via install.sh. The CK-Skills hooks below need manual wiring after symlinking. Both sets coexist under the same event keys.",

    "Notification": [
      {
        "_comment": "cc-dotfiles: macOS notification sound on model output",
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "_comment": "cc-dotfiles: auto-format Python files + update CRG graph after edits",
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/ruff-format.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/crg-update.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "_comment": "CK-Skills: soft gate — injects research checklist before edits",
        "matcher": "Edit|Write|Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/research-gate.sh"
          }
        ]
      },
      {
        "_comment": "CK-Skills: local TDD guard — requires a failing sail test marker before source edits",
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sail-tdd-guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "_comment": "cc-dotfiles: enforces /ship and /skiff completion gates",
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/ship-stop-gate.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/ship-skiff-stop-gate.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "_comment": "cc-dotfiles: shows pipeline stage + issue in the status bar",
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "_comment": "Optional — enable as needed",
    "warp@claude-code-warp": true,
    "frontend-design@claude-plugins-official": true
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "stable",
  "teammateMode": "tmux",
  "voiceEnabled": true
}
